# Pattern matching
# Expected output:
# the answer
# B
# 30
# hello

main do
  let result = match 42 do
    0 -> "zero"
    42 -> "the answer"
    _ -> "other"
  end
  print(result)

  let grade = match 85 do
    n if n >= 90 -> "A"
    n if n >= 80 -> "B"
    n if n >= 70 -> "C"
    _ -> "F"
  end
  print(grade)

  let (a, b) = (10, 20)
  print(a + b)

  let [first | rest] = ["hello", "world"]
  print(first)
end
